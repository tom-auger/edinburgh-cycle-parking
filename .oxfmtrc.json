{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "quoteProps": "as-needed",
  "singleQuote": true,
  "printWidth": 80,
  "ignorePatterns": ["next-env.d.ts"],
  "trailingComma": "all",
  "tabWidth": 2,
  "semi": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortPackageJson": false
}
