{
  "name": "neuk-bike",
  "version": "0.1.0",
  "private": true,
  "description": "Static mobile-friendly map for finding nearby Edinburgh cycle parking.",
  "keywords": [
    "active-travel",
    "cycle-parking",
    "cycling",
    "edinburgh",
    "map",
    "nextjs"
  ],
  "homepage": "https://neuk.bike",
  "bugs": {
    "url": "https://github.com/taugr/neuk-bike/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taugr/neuk-bike.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/generate-parking-share-pages.mjs",
    "start": "next start",
    "update:data": "node scripts/update-cycle-parking-data.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "posthog-js": "^1.374.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
